// Initialize by running "oxfmt --init"
{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "jsdoc": true,
  "jsxSingleQuote": true,
  "singleQuote": true,
  "sortImports": true,
  "sortTailwindcss": {
    "stylesheet": "./app/app.css",
    "functions": ["clsx", "cn", "cva", "tw"],
    "preserveWhitespace": true
  },
  "ignorePatterns": []
}
