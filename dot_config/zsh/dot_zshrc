# ${HOME}/.zshrc — interactive shell configuration
[[ -z "$PS1" ]] && return

# Path to zsh configs, distributed into smaller files
export ZDOTDIR="$HOME/.config/zsh"

### Environment

# Default language and collation
export LANG=en_US.UTF-8
export LC_COLLATE='C'

# Preferred editor, fallback chain
if command -v nvim >/dev/null 2>&1; then
    export EDITOR='nvim'; export VISUAL='nvim'
elif command -v vim >/dev/null 2>&1; then
    export EDITOR='vim'; export VISUAL='vim'
else
    export EDITOR='vi'; export VISUAL='vi'
fi

### History

HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=$HISTSIZE

setopt SHARE_HISTORY          # share across sessions
setopt EXTENDED_HISTORY       # timestamp per entry
setopt HIST_IGNORE_DUPS       # skip consecutive duplicates
setopt HIST_IGNORE_SPACE      # skip commands starting with space
setopt PUSHD_IGNORE_DUPS      # skip duplicate directory entries

### Keybindings

bindkey -e                    # Emacs mode

# Open current command in $EDITOR
autoload -U edit-command-line
zle -N edit-command-line
bindkey '\C-o' edit-command-line
bindkey '\C-x\C-e' edit-command-line

# Ctrl-R: incremental history search
bindkey '^r' history-incremental-search-backward

### Source modules

[[ -f "$ZDOTDIR"/function.zsh ]] && . "$ZDOTDIR/function.zsh"
[[ -f "$ZDOTDIR"/alias.zsh ]] && . "$ZDOTDIR/alias.zsh"
[[ -f "$ZDOTDIR"/completion.zsh ]] && . "$ZDOTDIR/completion.zsh"
[[ -f "$ZDOTDIR"/plugins/colorman.sh ]] && . "$ZDOTDIR/plugins/colorman.sh"

### Prompt

autoload -Uz promptinit && promptinit
autoload -U colors && colors      # ls colors

PROMPT_RANDOM_CANDIDATES=(bash simple zsh)
[[ -f "$ZDOTDIR"/random-theme.zsh ]] && . "$ZDOTDIR"/random-theme.zsh

### Tools

[[ -f "$ZDOTDIR"/tools.zsh ]] && . "$ZDOTDIR"/tools.zsh

### Languages

for f in "$ZDOTDIR"/langs/*.zsh(N); do
    . "$f"
done

### Lazy load

# Load thefuck on first use, not on shell start
if command_exists thefuck; then
    _my_lazyload_command_fuck() { eval "$(thefuck --alias)"; }
    my_lazyload_add_command fuck
fi

### Local overrides

# Machine-specific config, not tracked by chezmoi
[[ -f "$ZDOTDIR"/.zshrc.local ]] && . "$ZDOTDIR"/.zshrc.local
