# Screen configuration
# https://www.gnu.org/software/screen/manual/screen.html

# Detach on hangup
autodetach on

# UTF-8 encoding
defutf8 on

# Hide the startup copyright message
startup_message off

# Visual bell instead of audible
vbell on
vbell_msg " *beep* "

# Scrollback buffer
defscrollback 5000

# Silence timeout
silencewait 15

# Hardcopy directory
hardcopydir "$HOME/.hardcopy"

# Default shell
shell bash

# Render text colors
sorendition 10 99

# Status bar
hardstatus on
hardstatus alwayslastline "%0=%{kB}| %{kw}%h %{kB}|%=%{kR}Load: %l%100="

# Window list caption
caption always "%0=%{+b rk}%H %{bk}| %0L=%{mk}%>%-Lw%{= BW}%n%f* %t%{-}%+Lw%L>%?(%u)%? %{bk}|%>%=%{Yk} %=%C%A %Y.%m.%d %{bk}%100="

# Activity and bell notifications
activity "activity in %n (%t) [%w:%s]~"
bell "bell     in %n (%t) [%w:%s]~"
pow_detach_msg "Screen session of \$LOGNAME \$:cr:\$:nl:ended."

# === Key Bindings ===

# Use C-a as prefix
escape ^aa

# Split regions
bind | split -v     # horizontal split
bind - split        # vertical split

# Region navigation
bind h focus left
bind j focus down
bind k focus up
bind l focus right

# Resize regions
bind H resize -5
bind J resize +5
bind K resize -5
bind L resize +5

# Region management
bind Q only          # kill all other regions
bind X remove        # kill current region

# Tab/window navigation
bind C-h prev
bind C-l next
bind c screen         # new window
bind x kill           # kill current window

# Reload configuration
bind r source "$HOME/.config/screen/screenrc"

# Copy/scroll mode
bind Enter copy

# Copy mode keys (vi-style)
bindkey -d -k kb stuff ^h     # fix backspace in copy mode
bindkey -m h stuff ^b          # vi-style left
bindkey -m j stuff ^n          # vi-style down
bindkey -m k stuff ^p          # vi-style up
bindkey -m l stuff ^f          # vi-style right
bindkey -m y stuff ' '         # start selection
bindkey -m Y stuff 'y'         # copy selection
