# ${HOME}/.bashrc — interactive shell configuration
[[ $- != *i* ]] && return

# Path to bash configs, distributed into smaller files
export BASH="$HOME/.config/bash"

### Environment

# Default language and collation
export LANG=en_US.UTF-8
export LC_COLLATE='C'

# Preferred editor, fallback chain
if command -v nvim >/dev/null 2>&1; then
    export EDITOR='nvim'; export VISUAL='nvim'
elif command -v vim >/dev/null 2>&1; then
    export EDITOR='vim'; export VISUAL='vim'
else
    export EDITOR='vi'; export VISUAL='vi'
fi

### History

export HISTFILE="$HOME/.bash_history"
export HISTFILESIZE=10000
export HISTSIZE=10000
export HISTCONTROL='ignoreboth'     # ignoredups + ignorespace
export HISTIGNORE='&:bg:fg'         # skip simple commands
export HISTTIMEFORMAT='%F %T '      # timestamp format

### Source modules

[[ -f "$BASH"/function.sh ]] && . "$BASH"/function.sh
[[ -f "$BASH"/alias.sh ]] && . "$BASH"/alias.sh
[[ -f "$BASH"/plugins/colorman.sh ]] && . "$BASH"/plugins/colorman.sh

### Prompt

PROMPT_RANDOM_CANDIDATES=(bash simple zsh)
[[ -f "$BASH"/random-theme.sh ]] && . "$BASH"/random-theme.sh

### Path

add_path "$HOME"/.local/bin

### Tools

[[ -f "$BASH"/tools.sh ]] && . "$BASH"/tools.sh

### Languages

for f in "$BASH"/langs/*.sh; do
    [[ -f "$f" ]] && . "$f"
done

### Lazy load

# Load thefuck on first use, not on shell start
if command_exists thefuck; then
    _my_lazyload_command_fuck() { eval "$(thefuck --alias)"; }
    my_lazyload_add_command fuck
fi

### Local overrides

# Machine-specific config, not tracked by chezmoi
[[ -f "$BASH"/.bashrc.local ]] && . "$BASH"/.bashrc.local
